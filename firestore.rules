rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if the user is signed in
    function isSignedIn() {
      return request.auth != null;
    }

    // User profiles: Users can read any profile (for friends list), 
    // but can only write to their own.
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.auth.uid == userId;

      match /history/{docId} {
        allow read, write: if isSignedIn() && request.auth.uid == userId;
      }
    }

    // Login codes: Anyone can read a code to join/link, 
    // but only signed-in users (parents) can create them.
    match /loginCodes/{codeId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // Multiplayer Quests: Any signed-in user can join or update a quest 
    // (since it's a collaborative turn-based game).
    match /quests/{questId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn() && (resource.data.hostUid == request.auth.uid);
    }
  }
}
